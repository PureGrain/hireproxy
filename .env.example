# Required
ANTHROPIC_API_KEY=sk-ant-...

# Email channel (optional — remove if you don't need email interviews)
MAILGUN_API_KEY=your-mailgun-key
MAILGUN_DOMAIN=mail.yourdomain.com

# Discord notifications (optional — get a webhook URL from Discord channel settings)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# Security
PASSPHRASE=your-access-code
ADMIN_KEY=your-admin-key

# Display
BOT_NAME=AI Interview Assistant
CONTACT_EMAIL=you@example.com

# Limits
MESSAGE_CAP=150
PORT=3000
